n    {\n      \"title\": \"AI算力基础设施加速建设\",\n      \"summary\": \"光模块厂商华工科技确认800G产品需求放量，1.6T技术实现量产，反映AI算力投资持续高景气。\",\n      \"heat_score\": 85,\n      \"logic\": \"AI大模型训练推升高速光模块需求（新闻6、9）→头部厂商800G产品订单占比达40%且1.6T量产（新闻9）→数据中心资本开支向AI倾斜→算力产业链业绩确定性强化。\",\n      \"beneficiaries\": [\n        {\"ticker\": \"NVDA\", \"reason\": \"GPU需求与光模块升级周期深度绑定\"},\n        {\"ticker\": \"AVGO\", \"reason\": \"数据中心网络芯片龙头受益于带宽升级\"},\n        {\"ticker\": \"ANET\", \"reason\": \"云计算交换机厂商直接承接算力建设需求\"}\n      ],\n      \"detriments\": [\n        {\"ticker\": \"INTC\", \"reason\": \"传统CPU厂商在AI算力竞争中处于劣势\"},\n        {\"ticker\": \"WDC\", \"reason\": \"存储技术路线面临HBM替代压力\"}\n      ],\n      \"sources\": [\"https://example.com/optical_modules\"]\n    }\n  ]\n}"}
