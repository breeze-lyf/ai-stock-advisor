# Backend
DATABASE_URL=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Required security settings — generate with:
#   SECRET_KEY:     python -c "import secrets; print(secrets.token_hex(32))"
#   ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
ENCRYPTION_KEY=

# Optional — Redis for caching and distributed scheduler locks
# REDIS_URL=redis://localhost:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Environment flag for data source routing
# Set to "true" when running on server (e.g., Alibaba Cloud) without proxy
# Set to "false" (default) for local development with proxy
# This affects US stock data source selection:
#   - Server (true): Uses AkShare (more reliable without proxy)
#   - Local (false): Uses YFinance (better US stock coverage with proxy)
IS_SERVER_ENV=false

# Cloudflare Worker Proxy (optional - for bypassing Yahoo Finance restrictions)
# Deploy the worker script from cloudflare-worker/yahoo-proxy.js first
# CLOUDFLARE_WORKER_URL=https://yahoo-proxy.your-account.workers.dev
# CLOUDFLARE_WORKER_KEY=your-secret-key-here
